class Solution {
public:
   int maxsum;
   int solve(TreeNode *root)
   {
      if(root==NULL)
         return 0;

        int l=solve(root->left);
        int r=solve(root->right);

        int niche_hi_milgya_ans=l+r+root->val;
        int ek_side_only=max(l,r)+root->val;
        
        int only_root=root->val;

        maxsum=max({maxsum,niche_hi_milgya_ans,ek_side_only,only_root});

        return max(ek_side_only,only_root);
   }
    int maxPathSum(TreeNode* root) {
         maxsum=INT_MIN;
        solve(root);
       return maxsum;
    }
};
