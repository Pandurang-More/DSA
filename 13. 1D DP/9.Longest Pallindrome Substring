5. Longest Palindromic Substring

Given a string s, return the longest palindromic substring in s.

Example 1:

Input: s = "babad"
Output: "bab"

Explanation: "aba" is also a valid answer.

Example 2:

Input: s = "cbbd"
Output: "bb"

Constraints:

1 <= s.length <= 1000
s consist of only digits and English letters.

--------------------------------------------------
Brute Force
--------------------------------------------------

class Solution {
public:
    bool ispallindrome(string &s,int i,int j)
    {
        if(i>=j) return true;

        if(s[i]==s[j])
            return ispallindrome(s,i+1,j-1);
        else
            return false;
    }

    string longestPalindrome(string s) {
        int n=s.size();
        int maxlen=0;
        int sp=-1;

        for(int i=0;i<n;i++)
        {
            for(int j=i;j<n;j++)
            {
                if(ispallindrome(s,i,j) && j-i+1>maxlen)
                {
                    maxlen=j-i+1;
                    sp=i;
                }
            }
        }

        return s.substr(sp,maxlen);
    }
};

--------------------------------------------------
Memoization (Top Down)
--------------------------------------------------

class Solution {
public:
    int dp[1001][1001];

    bool ispallindrome(string &s,int i,int j)
    {
        if(dp[i][j]!=-1)
            return dp[i][j];

        if(i>=j) return true;

        if(s[i]==s[j])
            return dp[i][j]=ispallindrome(s,i+1,j-1);
        else
            return dp[i][j]=false;
    }

    string longestPalindrome(string s) {
        int n=s.size();
        int maxlen=0;
        int sp=-1;

        memset(dp,-1,sizeof(dp));

        for(int i=0;i<n;i++)
        {
            for(int j=i;j<n;j++)
            {
                if(ispallindrome(s,i,j) && j-i+1>maxlen)
                {
                    maxlen=j-i+1;
                    sp=i;
                }
            }
        }

        return s.substr(sp,maxlen);
    }
};

--------------------------------------------------
Bottom Up (Tabulation)
--------------------------------------------------

class Solution {
public:
    int t[1001][1001];

    string longestPalindrome(string s) {
        int n=s.size();
        int maxlen=1;
        int sp=0;

        for(int l=1;l<=n;l++)
        {
            for(int i=0;l+i-1<n;i++)
            {
                int j=l+i-1;

                if(i==j)
                {
                    t[i][j]=true;
                }
                else if(i+1==j)
                {
                    t[i][j]=(s[i]==s[j]);
                }
                else
                {
                    t[i][j]=(s[i]==s[j] && t[i+1][j-1]);
                }

                if(t[i][j] && l>maxlen)
                {
                    maxlen=l;
                    sp=i;
                }
            }
        }

        return s.substr(sp,maxlen);
    }
};
