Bottom up

class Solution {
public:
    int dp[101];
   
    int rob(vector<int>& nums) {
        int n=nums.size();
        dp[0]=nums[0];
        if(n>=2)
        dp[1]=max(nums[0],nums[1]);
        
        for(int i=2;i<n;i++)
        {
            dp[i]=max(dp[i-1],nums[i]+dp[i-2]);
        }
       
        
        return dp[n-1];
        
    }
};

Top Down
class Solution {
public:
    int dp[101];
    int solve(vector<int>&nums,int idx){
         if(idx<0)return 0;
         if(idx==0) 
         return nums[0];
        if(dp[idx]!=-1)
          return dp[idx];
        
        return dp[idx]=max(solve(nums,idx-1),nums[idx]+solve(nums,idx-2));
    }
   
    int rob(vector<int>& nums) {
        int n=nums.size();
        memset(dp,-1,sizeof(dp));
        return solve(nums,n-1);
        
    }
};
