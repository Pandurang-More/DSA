### Maximum Product Subarray

Given an integer array nums, find a subarray that has the largest product, and return the product.

The test cases are generated so that the answer will fit in a 32-bit integer.

Note that the product of an array with a single element is the value of that element.

Example 1:

Input: nums = [2,3,-2,4]
Output: 6

Explanation: [2,3] has the largest product 6.

Example 2:

Input: nums = [-2,0,-1]
Output: 0

Explanation: The result cannot be 2, because [-2,-1] is not a subarray.

Constraints:

1 <= nums.length <= 2 * 10^4
-10 <= nums[i] <= 10
The product of any subarray of nums is guaranteed to fit in a 32-bit integer.

--------------------------------------------------
Brute Force
--------------------------------------------------

class Solution {
public:
    int maxProduct(vector<int>& nums) {
        int n=nums.size();
        long long maxi=INT_MIN;
        for(int i=0;i<n;i++)
        {
            long long prod=1;
            for(int j=i;j<n;j++)
            {
                prod=prod*nums[j];
                maxi=max(maxi,prod);
            }
        }
        return maxi;
    }
};

--------------------------------------------------
Optimal
--------------------------------------------------

class Solution {
public:
    int maxProduct(vector<int>& nums) {
        int n=nums.size();
        int prefix=1;
        int suffix=1;
        int mp=INT_MIN;
        int sp=INT_MIN;
        int maxi=INT_MIN;

        for(int i=0;i<n;i++)
        {
            if(prefix==0) prefix=1;
            if(suffix==0) suffix=1;

            suffix*=nums[n-i-1];
            if(suffix>sp)
                sp=suffix;

            prefix*=nums[i];
            if(prefix>mp)
                mp=prefix;
        }

        return max(maxi,max(mp,sp));
    }
};

--------------------------------------------------
DP
--------------------------------------------------

class Solution {
public:
    int maxProduct(vector<int>& nums) {
        int n=nums.size();

        vector<int> maxprod(n);
        vector<int> minprod(n);

        maxprod[0]=nums[0];
        minprod[0]=nums[0];

        int ans=nums[0];

        for(int i=1;i<n;i++)
        {
            maxprod[i]=max({nums[i],
                            nums[i]*maxprod[i-1],
                            nums[i]*minprod[i-1]});

            minprod[i]=min({nums[i],
                            nums[i]*maxprod[i-1],
                            nums[i]*minprod[i-1]});

            ans=max(ans,maxprod[i]);
        }

        return ans;
    }
};
