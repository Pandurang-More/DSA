Top down : memoization

class Solution {
public:
    int a;
    int b;
    int dp[101][101];

    int solve(int i,int j)
    {
        if(i==a-1 && j==b-1)
            return 1;

        if(i>=a || i<0 || j>=b || j<0)
            return 0;

        if(dp[i][j]!=-1)
            return dp[i][j];

        int right=solve(i,j+1);
        int down=solve(i+1,j);

        return dp[i][j]=right+down;
    }

    int uniquePaths(int m, int n) {
        memset(dp,-1,sizeof(dp));

        a=m;
        b=n;

        return solve(0,0);
    }
};

