Given an array of string words, return all strings in words that are a substring of another word. 
You can return the answer in any order.

 

Example 1:
Input: words = ["mass","as","hero","superhero"]
Output: ["as","hero"]
Explanation: "as" is substring of "mass" and "hero" is substring of "superhero".
["hero","as"] is also a valid answer.

Example 2:
Input: words = ["leetcode","et","code"]
Output: ["et","code"]
Explanation: "et", "code" are substring of "leetcode".

Example 3:
Input: words = ["blue","green","bu"]
Output: []
Explanation: No string of words is substring of another string.


class Solution
{
public:
    vector<string> stringMatching(vector<string>& words)
    {
        vector<string> ans; // Stores all strings that are substrings of another string

        for (int i = 0; i < words.size(); i++)
        {
            for (int j = 0; j < words.size(); j++)
            {
                // Check different strings only
                // If words[j] is found inside words[i]
                if (i != j && words[i].find(words[j]) != string::npos)
                {
                    ans.push_back(words[j]); // Add substring to answer
                }
            }
        }

        // Sort so duplicate strings become adjacent
        sort(ans.begin(), ans.end());

        // Remove duplicate entries
        // unique() shifts duplicates to the end and returns
        // iterator pointing to the new logical end
        ans.erase(unique(ans.begin(), ans.end()), ans.end());

        return ans;
    }
};
