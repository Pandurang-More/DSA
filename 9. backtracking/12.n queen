class Solution {
public:
  vector<vector<string>>result;
  int N;
   
   bool isvalid(vector<string>&board,int row,int col)
   {
      // look upward
      for(int i=row-1;i>=0;i--)
      {
        if(board[i][col]=='Q')
        {
           return false;
        }
      }

      // look diagnoally right
      for(int i=row-1,j=col+1;i>=0&&j<=N;i--,j++)
      {
        if(board[i][j]=='Q')
        return false;
      }
      //look diagnally left
       for(int i=row-1,j=col-1;i>=0&&j>=0;i--,j--)
      {
        if(board[i][j]=='Q')
        return false;
      }
       return true;
   }

   void solve(vector<string>&board,int row)
   {
        if(row>=N)
        {
            result.push_back(board);
            return;
        }

        for(int col=0;col<N;col++)
        {
            if(isvalid(board,row,col))
            {
                board[row][col]='Q';

                solve(board,row+1);

                board[row][col]='.';
            }

        }
   }
    vector<vector<string>> solveNQueens(int n) {
        N=n;
        vector<string>board(n,string(n,'.'));

        solve(board,0);

        return result;
    }
};


Approach 2



class Solution {
public:
  vector<vector<string>>result;
  int N;
   
   unordered_set<int>cols;
   unordered_set<int>dig;
   unordered_set<int>antidig;

   void solve(vector<string>&board,int row)
   {
        if(row>=N)
        {
            result.push_back(board);
            return;
        }

        for(int col=0;col<N;col++)
        {
           int digc=row+col;
           int antidigc=row-col;
         
         if(cols.find(col)!=cols.end() || dig.find(digc)!=dig.end()|| antidig.find(antidigc)!=antidig.end())
         {
              continue;
         }

         cols.insert(col);
         dig.insert(digc);
         antidig.insert(antidigc);
         board[row][col]='Q';
         solve(board,row+1);
         
         cols.erase(col);
         dig.erase(digc);
         antidig.erase(antidigc);
         board[row][col]='.';



        }
   }
    vector<vector<string>> solveNQueens(int n) {
        N=n;
        vector<string>board(n,string(n,'.'));

        solve(board,0);

        return result;
    }
};
