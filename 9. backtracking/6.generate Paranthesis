====================================================

22. Generate Parentheses

Given n pairs of parentheses, write a function to generate all combinations of well-formed parentheses.

Example 1:

Input: n = 3
Output: ["((()))","(()())","(())()","()(())","()()()"]

Example 2:

Input: n = 1
Output: ["()"]

Constraints:

1 <= n <= 8

====================================================

Brute Force:

class Solution {
public:
    vector<string> result;

    bool isvalid(string s)
    {
        int count=0;

        for(char &ch:s)
        {
            if(ch=='(')
                count++;
            else
                count--;

            if(count<0)
                return false;
        }

        return count==0;
    }

    void solve(string &s,int n)
    {
        if(s.size()==2*n)
        {
            if(isvalid(s))
            {
                result.push_back(s);
            }
            return;
        }

        s.push_back('(');
        solve(s,n);
        s.pop_back();

        s.push_back(')');
        solve(s,n);
        s.pop_back();
    }

    vector<string> generateParenthesis(int n) {
        string s="";

        solve(s,n);

        return result;
    }
};

