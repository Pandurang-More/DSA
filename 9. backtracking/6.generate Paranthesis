Backtracking:

class Solution {
public:
    vector<string> result;

    void solve(string &s,int n,int open,int close)
    {
        if(s.size()==2*n)
        {
            result.push_back(s);
            return;
        }

        if(open<n)
        {
            s.push_back('(');
            solve(s,n,open+1,close);
            s.pop_back();
        }

        if(close<open)
        {
            s.push_back(')');
            solve(s,n,open,close+1);
            s.pop_back();
        }
    }

    vector<string> generateParenthesis(int n) {
        string s="";
        int open=0,close=0;

        solve(s,n,open,close);

        return result;
    }
};

